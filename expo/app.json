      "package": "app.rork.lnl2nmwo5fphaf5gc5xzg"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
